{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:fresh": "npm run clean && next dev",
    "clean": "node scripts/clean-next-cache.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "typecheck:database": "tsc --noEmit --project tsconfig.database.json",
    "test:ingestion": "tsx --test src/server/documents/*.test.ts",
    "test:embeddings": "tsx --test src/server/embeddings/*.test.ts",
    "test:retrieval": "tsx --test src/server/retrieval/*.test.ts",
    "test:rag": "tsx --test src/server/rag/*.test.ts",
    "test:chat": "tsx --test src/server/chat/*.test.ts",
    "test:engagement": "tsx --test src/server/analytics/*.test.ts src/server/feedback/*.test.ts",
    "test:security": "tsx --test src/server/http/*.test.ts",
    "test:backend": "npm run test:ingestion && npm run test:embeddings && npm run test:retrieval && npm run test:rag && npm run test:chat && npm run test:engagement && npm run test:security && npm run typecheck:database && npx drizzle-kit check",
    "ingest:uud": "tsx scripts/ingest-uud.ts",
    "embed:uud": "tsx scripts/embed-uud.ts",
    "evaluate:retrieval": "tsx scripts/evaluate-retrieval.ts",
    "evaluate:rag": "tsx scripts/evaluate-rag.ts",
    "db:check": "node scripts/check-database.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@google/genai": "^2.12.0",
    "@neondatabase/serverless": "^1.1.0",
    "drizzle-orm": "^0.45.2",
    "next": "15.5.20",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "pdf-parse": "^1.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
