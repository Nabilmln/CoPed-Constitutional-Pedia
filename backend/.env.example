# ===============================================
# CoPed - Environment Variables Template
# ===============================================
# ⚠️ IMPORTANT: Copy this file to .env and fill in your actual values
# Never commit .env file to version control!

# ================================
# MongoDB Atlas Configuration
# ================================
# Get this from MongoDB Atlas Dashboard
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/CoPed?retryWrites=true&w=majority&appName=YourApp

# ================================
# JWT Configuration
# ================================
# Generate a strong secret key (minimum 32 characters)
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_minimum_32_characters
JWT_EXPIRE=30d

# ================================
# Server Configuration
# ================================
PORT=5000
NODE_ENV=development

# ================================
# API Keys (REQUIRED)
# ================================
# Get your Gemini API key from Google AI Studio
# Visit: https://makersuite.google.com/app/apikey
# IMPORTANT: This is REQUIRED - service will fail to start if not set
GEMINI_API_KEY=your-gemini-api-key-here

# ================================
# Gemini Model Configuration
# ================================
# Default model to use for queries
# Options: gemini-1.5-flash (default, free tier) | gemini-2.5-flash (high accuracy) | gemini-2.0-flash (latest)
GEMINI_MODEL=gemini-1.5-flash

# ================================
# FastAPI Python Service Configuration
# ================================
# URL for the persistent Python RAG service
# Default: http://localhost:5001
PYTHON_SERVICE_URL=http://localhost:5001

# ================================
# Cache Configuration
# ================================
# Cache Time-To-Live in seconds (default: 3600 = 1 hour)
CACHE_TTL=3600

# Maximum number of cached query results (default: 100)
CACHE_MAX_SIZE=100

# ================================
# RAG Anti-Hallucination Configuration
# ================================
# Minimum relevance score threshold (0.0 - 1.0)
# Queries with relevance below this will return "not found" message
# Default: 0.3
RELEVANCE_THRESHOLD=0.3

# ================================
# Database Settings
# ================================
DB_NAME=CoPed

# ================================
# CORS Settings
# ================================
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ================================
# Upload Settings
# ================================
MAX_FILE_SIZE=10MB
UPLOAD_PATH=./uploads

# ================================
# RAG Configuration
# ================================
RAG_TIMEOUT=30000
MAX_CHAT_ROOMS=10
DEFAULT_RAG_SYSTEM=native

# ================================
# Logging
# ================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ================================
# Security Notes
# ================================
# - Never share your API keys
# - Use strong, unique passwords
# - Rotate keys regularly
# - Monitor usage for suspicious activity
# - GEMINI_API_KEY is required - the service will not start without it
