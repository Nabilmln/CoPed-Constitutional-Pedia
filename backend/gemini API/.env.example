# ===============================================
# CoPed Python RAG Service - Environment Variables
# ===============================================
# ⚠️ IMPORTANT: Copy this file to .env and fill in your actual values
# Never commit .env file to version control!

# ================================
# API Keys (REQUIRED)
# ================================
# Google Gemini API Key - REQUIRED for service to start
# Get your key from: https://makersuite.google.com/app/apikey
# The service will fail to start if this is not set
GEMINI_API_KEY=your-gemini-api-key-here

# ================================
# Gemini Model Configuration
# ================================
# Default model to use for RAG queries
# Options: 
#   - gemini-1.5-flash (default, free tier, fast)
#   - gemini-2.5-flash (high accuracy, best for complex queries)
#   - gemini-2.0-flash (latest model version)
GEMINI_MODEL=gemini-1.5-flash

# ================================
# FastAPI Service Configuration
# ================================
# Port for the FastAPI service to listen on
# Default: 5001
PYTHON_SERVICE_URL=http://localhost:5001

# ================================
# RAG Anti-Hallucination Configuration
# ================================
# Minimum relevance score threshold (0.0 - 1.0)
# Documents with relevance scores below this threshold will be ignored
# Higher values = stricter grounding, lower risk of hallucination
# Default: 0.3
RELEVANCE_THRESHOLD=0.3

# ================================
# Cache Configuration
# ================================
# Cache Time-To-Live in seconds
# Default: 3600 (1 hour)
CACHE_TTL=3600

# Maximum number of entries in the query cache
# Default: 100
CACHE_MAX_SIZE=100

# ================================
# Security Notes
# ================================
# - GEMINI_API_KEY is REQUIRED - service will not start without it
# - Never commit your .env file to version control
# - Never log or expose API keys in responses
# - Use .env.example for documentation only
# - Keep API keys secure and rotate regularly
